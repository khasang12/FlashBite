{
  "name": "flashbite",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:nuke": "docker compose -f infra/docker-compose.yml down -v",
    "infra:ps": "docker compose -f infra/docker-compose.yml ps",
    "test": "jest",
    "dev:write-api": "node -r @swc-node/register -r tsconfig-paths/register --env-file=.env apps/write-api/src/main.ts",
    "dev:outbox": "node -r @swc-node/register -r tsconfig-paths/register --env-file=.env apps/outbox-poller/src/main.ts",
    "dev:read-api": "node -r @swc-node/register -r tsconfig-paths/register --env-file=.env apps/read-api/src/main.ts",
    "dev:projection": "node -r @swc-node/register -r tsconfig-paths/register --env-file=.env apps/projection-worker/src/main.ts",
    "dev:saga": "node -r @swc-node/register -r tsconfig-paths/register --env-file=.env apps/saga-worker/src/main.ts",
    "dev:telemetry": "node -r @swc-node/register -r tsconfig-paths/register --env-file=.env apps/telemetry-worker/src/main.ts",
    "dev:web-customer": "pnpm --filter web-customer dev",
    "dev:web-merchant": "pnpm --filter web-merchant dev",
    "test:web": "pnpm --filter @flashbite/web-shared test",
    "test:e2e:web": "pnpm --filter web-customer test:e2e",
    "test:e2e:merchant": "pnpm --filter web-merchant test:e2e"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.23",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.12",
    "jest": "29.7.0",
    "ts-jest": "29.2.4",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.16.2",
    "typescript": "5.5.4"
  }
}
