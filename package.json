{
  "name": "flashbite",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:nuke": "docker compose -f infra/docker-compose.yml down -v",
    "infra:ps": "docker compose -f infra/docker-compose.yml ps",
    "test": "jest",
    "dev:write-api": "tsx --tsconfig apps/write-api/tsconfig.json --env-file=.env apps/write-api/src/main.ts",
    "dev:outbox": "tsx --tsconfig apps/outbox-poller/tsconfig.json --env-file=.env apps/outbox-poller/src/main.ts"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "tsx": "4.16.2",
    "@types/node": "20.14.12",
    "jest": "29.7.0",
    "ts-jest": "29.2.4",
    "@types/jest": "29.5.12",
    "tsconfig-paths": "4.2.0"
  }
}
