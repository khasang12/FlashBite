# FlashBite — manual HTTP requests (write-api command side + read-api query/telemetry)
#
# Works with the VS Code "REST Client" extension and JetBrains HTTP Client.
# Prereqs:
#   pnpm infra:up          # Postgres + Redpanda + MongoDB + Redis Cluster running
#   pnpm db:deploy         # apply migrations + create the flashbite_app RLS role (Phase 2 S2)
#   pnpm dev:write-api     # http://localhost:3001 (command side)
#   pnpm dev:outbox        # relays outbox -> order-events
#   pnpm dev:projection    # order-events -> MongoDB read model
#   pnpm dev:read-api      # http://localhost:3002 (query side: orders + SSE + drivers)
#   pnpm dev:telemetry     # telemetry-streams -> Redis geo (driver locations)
#   pnpm dev:identity      # http://localhost:3003 (Phase 2a: login + JWKS)
#   pnpm seed:users        # seed demo users (role@tenant.test, e.g. merchant@berlin.test)
#
# Phase 2 S2 — Postgres Row-Level Security: write-api + saga-worker connect as the
# restricted `flashbite_app` role (set APP_DATABASE_URL in .env — see .env.example) and
# set app.tenant_id per write transaction, so a tenant can only write/read its own
# event_store/outbox rows. The outbox-poller stays on the superuser DATABASE_URL. If
# APP_DATABASE_URL is unset, write-api falls back to the superuser (RLS not exercised).
#
# Note on random ids: {{$guid}} is the VS Code REST Client generator.
# In JetBrains HTTP Client use {{$random.uuid}} instead.

@baseUrl = http://localhost:3001
@readUrl = http://localhost:3002
@identityUrl = http://localhost:3003
@seedPassword = devpassword
# Fixed id so the "place" + "re-place" pair below exercises idempotency.
@orderId = 31111111-1111-1111-1111-111111111112
# Fixed driver id so the location POST + nearby query below correlate.
@driverId = drv-1

# ============================================================================
# Phase 2 — identity service (port 3003). Unauthenticated issuer of RS256 JWTs.
# Prereqs: pnpm dev:identity  +  pnpm seed:users  (seeds role@tenant.test users).
# Login resolves tenant + role from the user row — NOT from a header.
#
# HOW TO USE THIS FILE (Phase 2):
#   1. Run the three login requests below (login, loginCustomer, loginTokyo) first.
#      The REST Client captures each response token automatically.
#   2. Every write-api and read-api request then sends:
#        Authorization: Bearer <captured token>
#      The token carries tenantId + role — the old X-Tenant-ID header is no longer
#      accepted and will be ignored by the services.
#   3. To exercise a different tenant or role, log in as that user and use its token.
#      - Berlin merchant ops (accept/decline): {{login...}} (merchant@berlin.test)
#      - Berlin order placement + reads:       {{loginCustomer...}} (customer@berlin.test)
#      - Tokyo order placement + reads:        {{loginTokyo...}} (customer@tokyo.test)
# ============================================================================

### Identity health. Expect 200 { "status": "ok" }.
GET {{identityUrl}}/health

### Log in as a berlin merchant. Expect 201 { accessToken, tokenType: "Bearer", expiresIn: 3600 }.
### The JWT carries sub + tenantId=berlin + role=merchant (decode at jwt.io to inspect).
# @name login
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "merchant@berlin.test",
  "password": "{{seedPassword}}"
}

### Log in as a berlin customer so order-placement requests below carry the right role.
# @name loginCustomer
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "customer@berlin.test",
  "password": "{{seedPassword}}"
}

### Log in as a tokyo customer so the tokyo requests below carry a tokyo token.
# @name loginTokyo
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "customer@tokyo.test",
  "password": "{{seedPassword}}"
}

### JWKS — the public keys used to verify the token above. Expect 200 { "keys": [ ... ] }
### (public material only — no d/p/q). `kid` matches the token header's `kid`.
GET {{identityUrl}}/.well-known/jwks.json

### Bearer-header shape using the captured token. Health is open — this just confirms
### the token is well-formed and accepted (returns 200 regardless).
GET {{identityUrl}}/health
Authorization: Bearer {{login.response.body.$.accessToken}}

### Log in as the platform operator (cross-tenant console). Expect 201.
# @name loginOperator
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "operator@flashbite.test",
  "password": "{{seedPassword}}"
}

### Phase 3c-iii — customer confirms payment (unblocks the saga authorize). Expect 202.
POST {{baseUrl}}/orders/{{orderId}}/confirm-payment
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

### Phase 3d — log in as a berlin driver. Expect 201.
# @name loginDriver
POST {{identityUrl}}/auth/login
Content-Type: application/json

{ "email": "driver@berlin.test", "password": "{{seedPassword}}" }

### Driver goes online (so dispatch can offer jobs). Expect 202.
POST {{readUrl}}/drivers/{{driverId}}/online
Authorization: Bearer {{loginDriver.response.body.$.accessToken}}

### Driver accepts / picks up / delivers the dispatch (after an order is accepted). Expect 202.
POST {{baseUrl}}/dispatch/{{orderId}}/accept
Authorization: Bearer {{loginDriver.response.body.$.accessToken}}
Content-Type: application/json

{ "driverId": "{{driverId}}" }

### Current dispatch for an order (assigned driver + status).
GET {{readUrl}}/orders/{{orderId}}/dispatch
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

### Operator: all orders across every tenant. Expect 200 OrderView[] spanning berlin + tokyo.
GET {{readUrl}}/admin/orders
Authorization: Bearer {{loginOperator.response.body.$.accessToken}}

### Operator: live drivers across every tenant (tagged by tenantId). Expect 200.
GET {{readUrl}}/admin/drivers
Authorization: Bearer {{loginOperator.response.body.$.accessToken}}

### Operator SSE: merged order-event stream across all tenants. Stays open.
GET {{readUrl}}/admin/orders/stream
Authorization: Bearer {{loginOperator.response.body.$.accessToken}}
Accept: text/event-stream

### A non-operator token on /admin -> 403 (reuses the merchant login above).
GET {{readUrl}}/admin/orders
Authorization: Bearer {{login.response.body.$.accessToken}}

### Log in as the tokyo admin — different tenantId + role in the token. Expect 201.
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@tokyo.test",
  "password": "{{seedPassword}}"
}

### Wrong password. Expect 401 { "message": "Invalid email or password" }.
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "merchant@berlin.test",
  "password": "wrong"
}

### Unknown email. Expect 401 — SAME generic message (no user enumeration).
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "nobody@berlin.test",
  "password": "{{seedPassword}}"
}

### Malformed body (not an email, no password). Expect 400 Bad Request (ValidationPipe).
POST {{identityUrl}}/auth/login
Content-Type: application/json

{
  "email": "not-an-email"
}

### Health — unauthenticated, always open. Expect 200 { "status": "ok" }.
GET {{baseUrl}}/health

### No token on a protected endpoint -> 401 (the trusted-header fallback is gone in Phase 2).
GET {{readUrl}}/orders/{{orderId}}

### Place an order (fixed id). Expect 201 { "orderId": "1111...1111" }.
### Uses customer token — write-api enforces role=customer for order placement.
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "orderId": "{{orderId}}",
  "customerId": "c-1",
  "items": [{ "sku": "pizza", "qty": 1, "price": 1200 }],
  "totalAmount": 1200
}

### Re-place the SAME order -> idempotent. Expect 201, same orderId,
### and STILL exactly one event_store row + one outbox row (no duplicate).
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "orderId": "{{orderId}}",
  "customerId": "c-1",
  "items": [{ "sku": "pizza", "qty": 1, "price": 1200 }],
  "totalAmount": 1200
}

### Place a FRESH random order each run. Expect 201 with a new orderId.
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "orderId": "{{$guid}}",
  "customerId": "c-2",
  "items": [
    { "sku": "burger", "qty": 2, "price": 950 },
    { "sku": "fries", "qty": 1, "price": 400 }
  ],
  "totalAmount": 2300
}

### Different tenant (tokyo) — token-based tenant routing (Phase 2).
### Lands under tenant_id=tokyo; token carries tenantId=tokyo + role=customer.
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{loginTokyo.response.body.$.accessToken}}

{
  "orderId": "{{$guid}}",
  "customerId": "c-9",
  "items": [{ "sku": "sushi", "qty": 3, "price": 800 }],
  "totalAmount": 2400
}

### Validation: missing required fields -> 400 Bad Request
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "orderId": "bad-1"
}

### Validation: empty items array + bad types -> 400 Bad Request
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "orderId": "{{$guid}}",
  "customerId": "c-3",
  "items": [],
  "totalAmount": -5
}

# ============================================================================
# read-api (query side, port 3002) — run after placing an order on write-api;
# give dev:outbox + dev:projection a moment to flow the event into MongoDB.
# ============================================================================

### read-api health — open endpoint, no auth required.
GET {{readUrl}}/health

### Query the fixed order placed above. Expect 200 OrderView (status PLACED).
### First call reads Mongo + populates the Redis cache; repeat within 10s = cache hit.
GET {{readUrl}}/orders/{{orderId}}
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

### Query a non-existent order -> 404
GET {{readUrl}}/orders/{{$guid}}
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

### Tenant isolation: the berlin order is NOT visible to a tokyo token -> 404
GET {{readUrl}}/orders/{{orderId}}
Authorization: Bearer {{loginTokyo.response.body.$.accessToken}}

### Phase 3c-ii — payment status for an order (tenant from JWT, read-through to payments).
### 200 { "status": "AUTHORIZED" | "CAPTURED" | "VOIDED" | "DECLINED" } or { "status": null }.
GET {{readUrl}}/orders/{{orderId}}/payment
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

### Internal payments read (no JWT) — what read-api calls server-to-server. @payments = :3004.
### Run pnpm dev:payments first. 200 { orderId, status, amount } or 404 when no payment.
GET http://localhost:3004/payments/berlin/{{orderId}}

### SSE merchant feed (streams live order events for the tenant).
### This connection stays OPEN — place an order on write-api in another request
### and watch the event arrive here. Cancel the request to close the stream.
GET {{readUrl}}/merchant/orders/stream
Authorization: Bearer {{login.response.body.$.accessToken}}
Accept: text/event-stream

# ============================================================================
# Phase 1c-ii — driver telemetry (read-api, port 3002).
# Ephemeral: POST -> DriverTelemetryStreamed on telemetry-streams -> telemetry-worker
# GEOADDs the driver into {tenant:<id>}:drivers:geo. Requires `pnpm dev:telemetry`
# running for the ping to land; GET /drivers/nearby reads it back via GEOSEARCH
# (tenant-scoped). Telemetry never touches Postgres / the event store.
# ============================================================================

### Stream a driver GPS ping (Berlin centre). Expect 202 { "driverId": "drv-1" }.
POST {{readUrl}}/drivers/{{driverId}}/location
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "lng": 13.405,
  "lat": 52.52
}

### Another ping with an optional orderId (driver en route to an order). Expect 202.
POST {{readUrl}}/drivers/{{driverId}}/location
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "lng": 13.408,
  "lat": 52.521,
  "orderId": "{{orderId}}"
}

### Nearby drivers within 5km of Berlin centre. After dev:telemetry consumes the
### ping(s) above, expect 200 with drv-1 (small distanceKm). Run a couple seconds later.
GET {{readUrl}}/drivers/nearby?lng=13.405&lat=52.52&radiusKm=5
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

### Tenant isolation: tokyo token does NOT see berlin's drivers. Expect 200 [] (no drv-1).
GET {{readUrl}}/drivers/nearby?lng=13.405&lat=52.52&radiusKm=5
Authorization: Bearer {{loginTokyo.response.body.$.accessToken}}

### Validation: out-of-range coords -> 400 Bad Request (controller-scoped ValidationPipe).
POST {{readUrl}}/drivers/{{driverId}}/location
Content-Type: application/json
Authorization: Bearer {{loginCustomer.response.body.$.accessToken}}

{
  "lng": 999,
  "lat": 52.52
}

# ----------------------------------------------------------------------------
# Verifying side effects (run in a shell after POSTing):
#
#   # event_store + outbox rows for the fixed order:
#   docker exec $(docker compose -f infra/docker-compose.yml ps -q postgres) \
#     psql -U flashbite -d flashbite_write \
#     -c "select event_type, version from event_store where aggregate_id='11111111-1111-1111-1111-111111111111';" \
#     -c "select status, partition_key from outbox where partition_key='berlin:11111111-1111-1111-1111-111111111111';"
#
#   # envelope on the topic (after dev:outbox relays it):
#   docker exec $(docker compose -f infra/docker-compose.yml ps -q redpanda) \
#     rpk topic consume order-events --brokers redpanda:29092 --num 5 --offset end:-5
#
#   # telemetry envelopes on the stream (after POSTing a driver location):
#   docker exec $(docker compose -f infra/docker-compose.yml ps -q redpanda) \
#     rpk topic consume telemetry-streams --brokers redpanda:29092 --num 5 --offset end:-5
#
#   # live driver positions in Redis geo (ephemeral). The cluster key is hash-tagged
#   # {tenant:berlin}:drivers:geo so all members co-locate on one slot:
#   docker exec $(docker compose -f infra/docker-compose.yml ps -q redis-cluster) \
#     redis-cli -c -p 7100 GEOSEARCH "{tenant:berlin}:drivers:geo" \
#     FROMLONLAT 13.405 52.52 BYRADIUS 5 km ASC WITHDIST WITHCOORD
#
#   # Phase 2 S2 — see RLS actually enforce. The psql commands above use -U flashbite
#   # (SUPERUSER), which BYPASSES RLS and sees every tenant. To watch the policy bite,
#   # connect as the restricted flashbite_app role and set the tenant GUC per query:
#   docker exec -e PGPASSWORD=flashbite_app_local_dev \
#     $(docker compose -f infra/docker-compose.yml ps -q postgres) \
#     psql -U flashbite_app -d flashbite_write \
#     -c "SELECT count(*) AS visible_without_guc FROM event_store;" \  # 0 (fail-closed)
#     -c "BEGIN; SELECT set_config('app.tenant_id','berlin',true); \
#         SELECT count(*) AS berlin_rows FROM event_store; \
#         SELECT count(*) AS tokyo_rows  FROM event_store WHERE tenant_id='tokyo'; COMMIT;"
#   # Expect: visible_without_guc=0; berlin_rows>0; tokyo_rows=0 (other tenants hidden).
# ----------------------------------------------------------------------------
