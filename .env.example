# --- Postgres (application: event store + outbox) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=flashbite
PG_PASSWORD=local_dev_only_change_me
PG_DB=flashbite_write
DATABASE_URL=postgresql://flashbite:local_dev_only_change_me@localhost:5432/flashbite_write
# Restricted role used by write-api + saga-worker so Postgres RLS enforces tenant isolation
# (the default DATABASE_URL role is a superuser and bypasses RLS). Created by the
# 20260616000000_rls_event_store_outbox migration. Local-dev password only.
APP_DATABASE_URL="postgresql://flashbite_app:flashbite_app_local_dev@localhost:5432/flashbite_write?schema=public"

# --- Redpanda (Kafka API) ---
KAFKA_BROKERS=localhost:9092
# Redpanda Schema Registry (Avro). Default matches infra/docker-compose.yml.
SCHEMA_REGISTRY_URL=http://localhost:18081

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233

# --- Redis Cluster (6 nodes, single-container grokzen, host-mapped) ---
REDIS_CLUSTER_NODES=127.0.0.1:7100,127.0.0.1:7101,127.0.0.1:7102,127.0.0.1:7103,127.0.0.1:7104,127.0.0.1:7105

# --- MongoDB (read models) ---
MONGO_URI=mongodb://localhost:27017/flashbite_read

# Identity (Phase 2a)
IDENTITY_PORT=3003
JWT_ISSUER=flashbite-identity
JWT_AUDIENCE=flashbite
JWT_ACCESS_TTL=3600
SEED_USER_PASSWORD=devpassword

# --- Frontend API origin overrides (Next.js rewrites, Phase 2 S4) ---
# These default to localhost; only set them in non-local environments (e.g. staging, containers).
# IDENTITY_API_ORIGIN=http://localhost:3003
# READ_API_ORIGIN=http://localhost:3002
# WRITE_API_ORIGIN=http://localhost:3001
